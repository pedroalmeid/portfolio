---
import '../../styles/global.css';
import { getEntry } from 'astro:content';
import avatarImg from '../../assets/avatar.png';
import { Home, FileText, Briefcase, BookOpen, Send, Mail, Menu } from '@lucide/astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Pedro José Campos de Almeida | Portfólio", 
  description = "Portfólio de Pedro José Campos de Almeida, estudante de Ciência da Computação na UFJF e pesquisador em sistemas distribuídos." 
} = Astro.props;

// Get sidebar content
const sidebarEntry = await getEntry('info', 'sidebar');
if (!sidebarEntry || sidebarEntry.data.schemaType !== 'sidebar') {
  throw new Error('Falha ao carregar dados da barra lateral (sidebar.json).');
}

const sidebarData = sidebarEntry.data;

// Get current path for active links
const pathname = Astro.url.pathname;
const cleanPath = pathname.replace(/\/$/, "");

const navItems = [
  { href: "/", label: "Home", icon: Home },
  { href: "/cv", label: "Currículo", icon: FileText },
  { href: "/projetos", label: "Projetos", icon: Briefcase },
  { href: "/papers", label: "Publicações", icon: BookOpen },
  { href: "/contato", label: "Contato", icon: Send },
];
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-white text-text-primary flex flex-col md:flex-row antialiased">
    
    <!-- Mobile Header -->
    <div class="md:hidden flex items-center justify-between px-6 py-4 border-b border-border bg-[#fafafa] sticky top-0 z-50">
      <a href="/" class="flex items-center space-x-3">
        <img src={avatarImg.src} alt={sidebarData.name} class="w-8 h-8 rounded-full border border-border object-cover" />
        <div>
          <div class="font-bold text-sm text-text-primary leading-tight">{sidebarData.name}</div>
          <div class="text-[10px] text-text-secondary leading-none">{sidebarData.subtitle}</div>
        </div>
      </a>
      <button id="menu-toggle" class="p-2 text-text-secondary hover:text-text-primary focus:outline-none" aria-label="Toggle menu">
        <Menu class="h-6 w-6" />
      </button>
    </div>

    <!-- Sidebar Backdrop (Mobile overlay) -->
    <div id="sidebar-backdrop" class="fixed inset-0 bg-[#0a0a0a]/30 z-30 hidden md:hidden"></div>

    <!-- Sidebar (Global sticky sidebar) -->
    <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-60 bg-[#fafafa] border-r border-border flex flex-col justify-between p-6 transition-transform -translate-x-full md:translate-x-0 md:sticky md:top-0 md:h-screen overflow-y-auto shrink-0 select-none">
      
      <!-- Top Section (Avatar and Info) -->
      <div class="space-y-6">
        <div class="space-y-3">
          <img src={avatarImg.src} alt={sidebarData.name} class="w-12 h-12 rounded-full border border-border object-cover" />
          <div>
            <h2 class="font-bold text-base text-text-primary leading-snug">{sidebarData.name}</h2>
            <p class="text-xs text-text-secondary">{sidebarData.subtitle}</p>
          </div>
          
          <!-- Opportunities Status (Simple text and dot, no badge card) -->
          <div class="flex items-center space-x-1.5 text-xs text-text-secondary">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
            <span>{sidebarData.status}</span>
          </div>
        </div>

        <hr class="border-t border-border" />

        <!-- Navigation Links -->
        <nav class="space-y-1.5">
          {navItems.map((item) => {
            const IconComponent = item.icon;
            const isActive = cleanPath === item.href.replace(/\/$/, "");
            return (
              <a 
                href={item.href}
                class={`flex items-center justify-between px-3 py-2 rounded-lg text-sm transition-all duration-150 ${
                  isActive 
                    ? 'bg-white border border-border shadow-xs text-text-primary font-semibold' 
                    : 'text-text-secondary hover:bg-bg-hover hover:text-text-primary'
                }`}
              >
                <div class="flex items-center space-x-3">
                  <span class={isActive ? 'text-accent' : 'text-text-secondary'}>
                    <IconComponent class="w-4.5 h-4.5" />
                  </span>
                  <span>{item.label}</span>
                </div>
                {isActive && <span class="w-1.5 h-4 rounded-full bg-accent" />}
              </a>
            )
          })}
        </nav>
      </div>

      <!-- Bottom Section (Socials & Copyright) -->
      <div class="space-y-4 mt-8">
        <!-- Social Icons -->
        <div class="flex items-center space-x-4">
          {sidebarData.socials.map((social) => {
            return (
              <a 
                href={social.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-text-secondary hover:text-accent transition-colors"
                aria-label={social.name}
              >
                {social.icon === 'github' && (
                  <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                  </svg>
                )}
                {social.icon === 'linkedin' && (
                  <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
                  </svg>
                )}
                {social.icon === 'email' && <Mail class="w-4.5 h-4.5" />}
              </a>
            )
          })}
        </div>
        
        <!-- Copyright -->
        <p class="text-[10px] text-text-secondary/70 leading-normal">
          {sidebarData.copyright}
        </p>
      </div>

    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col min-h-screen min-w-0 bg-white">
      <!-- Main Content -->
      <main class="flex-1 w-full max-w-2xl px-6 pt-12 pb-32 md:px-16 md:pt-16 md:pb-48">
        <slot />
      </main>
    </div>

    <!-- Mobile Drawer Script -->
    <script is:inline>
      (function() {
        const toggleBtn = document.getElementById('menu-toggle');
        const sidebar = document.getElementById('sidebar');
        const backdrop = document.getElementById('sidebar-backdrop');

        if (toggleBtn && sidebar && backdrop) {
          function openMenu() {
            sidebar.classList.remove('-translate-x-full');
            backdrop.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
          }

          function closeMenu() {
            sidebar.classList.add('-translate-x-full');
            backdrop.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
          }

          toggleBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            if (sidebar.classList.contains('-translate-x-full')) {
              openMenu();
            } else {
              closeMenu();
            }
          });

          backdrop.addEventListener('click', closeMenu);

          // Close menu on link click (mobile)
          const links = sidebar.querySelectorAll('nav a');
          links.forEach(function(link) {
            link.addEventListener('click', closeMenu);
          });
        }
      })();
    </script>

  </body>
</html>
