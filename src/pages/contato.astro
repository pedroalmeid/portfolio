---
import BaseLayout from '../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';

const contactEntry = await getEntry('info', 'contact');
if (!contactEntry || contactEntry.data.schemaType !== 'contact') {
  throw new Error('Falha ao carregar dados de contato (contact.json).');
}

const { email, github, linkedin } = contactEntry.data;
---

<BaseLayout title="Fale Comigo | Daniel Silva" description="Entre em contato com Daniel Silva para parcerias, consultorias ou discussões técnicas.">
  <div class="space-y-12">
    <!-- Header -->
    <div class="space-y-4">
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight">
        Fale <span class="gradient-text">Comigo</span>
      </h1>
      <p class="text-slate-400 text-base sm:text-lg max-w-2xl font-light">
        Interessado em arquiteturas estáticas de alta performance ou consultorias técnicas? Entre em contato preenchendo o formulário ou através das redes.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
      <!-- Info Cards (2/5 size) -->
      <div class="md:col-span-2 space-y-6">
        <!-- Direct Email -->
        <div class="p-6 rounded-2xl glass">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400 mb-2">E-mail Direto</h2>
          <a href={`mailto:${email}`} class="text-lg font-bold text-white hover:text-brand-cyan transition-colors break-all">
            {email}
          </a>
        </div>

        <!-- Social Media Links -->
        <div class="p-6 rounded-2xl glass space-y-4">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Redes Sociais</h2>
          
          <div class="flex flex-col space-y-3">
            <a 
              href={github} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center space-x-3 text-slate-300 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
              <span class="font-medium text-sm">GitHub</span>
            </a>
            
            <a 
              href={linkedin} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center space-x-3 text-slate-300 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              <span class="font-medium text-sm">LinkedIn</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form (3/5 size) -->
      <form class="md:col-span-3 p-8 rounded-2xl glass space-y-6" onsubmit="event.preventDefault(); alert('Mensagem enviada com sucesso! (Demonstração)');">
        <h2 class="text-xl font-bold text-white mb-2">Envie uma Mensagem</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label for="name" class="text-xs font-semibold text-slate-300 uppercase tracking-wider">Nome</label>
            <input 
              type="text" 
              id="name" 
              required 
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:border-brand-cyan transition-colors"
              placeholder="Seu nome"
            />
          </div>
          <div class="space-y-2">
            <label for="form-email" class="text-xs font-semibold text-slate-300 uppercase tracking-wider">E-mail</label>
            <input 
              type="email" 
              id="form-email" 
              required 
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:border-brand-cyan transition-colors"
              placeholder="seu.email@exemplo.com"
            />
          </div>
        </div>

        <div class="space-y-2">
          <label for="subject" class="text-xs font-semibold text-slate-300 uppercase tracking-wider">Assunto</label>
          <input 
            type="text" 
            id="subject" 
            required 
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:border-brand-cyan transition-colors"
            placeholder="Assunto do contato"
          />
        </div>

        <div class="space-y-2">
          <label for="message" class="text-xs font-semibold text-slate-300 uppercase tracking-wider">Mensagem</label>
          <textarea 
            id="message" 
            rows="5" 
            required 
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:border-brand-cyan transition-colors resize-none"
            placeholder="Escreva sua mensagem aqui..."
          ></textarea>
        </div>

        <button 
          type="submit" 
          class="w-full py-3 rounded-lg text-sm font-semibold bg-linear-to-r from-brand-purple to-brand-cyan text-white hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer"
        >
          Enviar Mensagem
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
