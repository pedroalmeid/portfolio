---
import BaseLayout from '../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { Mail, MessageSquare, MapPin } from '@lucide/astro';

const contactEntry = await getEntry('info', 'contact');
if (!contactEntry || contactEntry.data.schemaType !== 'contact') {
  throw new Error('Falha ao carregar dados de contato (contact.json).');
}

const { title, description, email, github, linkedin, discord, location } = contactEntry.data;
---

<BaseLayout title={`${title} | Pedro José`} description={description}>
  <div class="space-y-8 max-w-2xl">
    
    <!-- Header Section -->
    <div class="space-y-4">
      <span class="c-section-label">Contato</span>
      
      <h1 class="font-extrabold text-text-primary text-[2.5rem] leading-[1.15] tracking-tight">
        {title}
      </h1>
      
      <p class="text-text-secondary text-sm leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Contact List (Simple vertical format matching prototype) -->
    <div class="flex flex-col gap-4 pt-4">
      
      <!-- Email -->
      <div class="flex items-center space-x-3.5">
        <div class="w-7 h-7 flex items-center justify-center rounded-full border border-border bg-bg-card text-text-secondary select-none">
          <Mail class="w-3.5 h-3.5" />
        </div>
        <a href={`mailto:${email}`} class="text-sm text-text-secondary hover:text-accent transition-colors">
          {email}
        </a>
      </div>

      <!-- GitHub -->
      <div class="flex items-center space-x-3.5">
        <div class="w-7 h-7 flex items-center justify-center rounded-full border border-border bg-bg-card text-text-secondary select-none">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <a 
          href={`https://${github}`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-sm text-text-secondary hover:text-accent transition-colors"
        >
          {github}
        </a>
      </div>

      <!-- LinkedIn -->
      <div class="flex items-center space-x-3.5">
        <div class="w-7 h-7 flex items-center justify-center rounded-full border border-border bg-bg-card text-text-secondary select-none">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
          </svg>
        </div>
        <a 
          href={`https://${linkedin}`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-sm text-text-secondary hover:text-accent transition-colors"
        >
          {linkedin}
        </a>
      </div>

      <!-- Discord -->
      <div class="flex items-center space-x-3.5">
        <div class="w-7 h-7 flex items-center justify-center rounded-full border border-border bg-bg-card text-text-secondary select-none">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.894.077.077 0 0 1-.008-.128c.126-.093.252-.19.372-.287a.075.075 0 0 1 .077-.011 13.983 13.983 0 0 0 12.01 0 .073.073 0 0 1 .078.009c.12.099.246.195.373.289a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.894.077.077 0 0 0-.041.107 14.36 14.36 0 0 0 1.226 1.99.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.156 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.156 2.418z" />
          </svg>
        </div>
        <span class="text-sm text-text-secondary select-all">
          {discord}
        </span>
      </div>

      <!-- Location -->
      <div class="flex items-center space-x-3.5">
        <div class="w-7 h-7 flex items-center justify-center rounded-full border border-border bg-bg-card text-text-secondary select-none">
          <MapPin class="w-3.5 h-3.5" />
        </div>
        <span class="text-sm text-text-secondary">
          {location}
        </span>
      </div>

    </div>
  </div>
</BaseLayout>
