---
import BaseLayout from '../components/astro/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

const homeEntry = await getEntry('info', 'home');
if (!homeEntry || homeEntry.data.schemaType !== 'home') {
  throw new Error('Falha ao carregar dados da página inicial (home.json).');
}

const { heroTitle, bio, contactBtnText, cvBtnText, highlights, aboutTitle, aboutText } = homeEntry.data;

// Fetch project cases
const allCases = await getCollection('cases');

// Fetch papers
const papersEntry = await getEntry('info', 'papers');
const allPapers = papersEntry && papersEntry.data.schemaType === 'papers' ? papersEntry.data.papers : [];

// Resolve highlight items
const resolvedHighlights = highlights.map(hl => {
  if (hl.type === 'project') {
    const project = allCases.find(c => c.id === hl.id);
    return { type: 'project', data: project };
  } else if (hl.type === 'paper') {
    const paper = allPapers.find(p => p.id === hl.id);
    return { type: 'paper', data: paper };
  }
  return null;
}).filter(hl => hl && hl.data);
---

<BaseLayout title={heroTitle} description="Portfólio acadêmico e profissional de Pedro José Campos de Almeida.">
  <div class="space-y-16">
    
    <!-- Hero / Intro Section -->
    <section class="space-y-6">
      <h1 class="font-extrabold text-text-primary text-5xl leading-tight tracking-tight select-none">
        {heroTitle.split(' ').slice(0, 2).join(' ')}<br />
        {heroTitle.split(' ').slice(2).join(' ')}
      </h1>
      
      <p class="text-text-secondary text-sm leading-relaxed max-w-2xl" set:html={bio}>
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-wrap gap-3 pt-2">
        <a href="/contato" class="btn-primary">
          <!-- Envelope Icon -->
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>{contactBtnText}</span>
        </a>
        
        <a href="/cv" class="btn-secondary">
          <!-- Download Icon -->
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span>{cvBtnText}</span>
        </a>
      </div>
    </section>

    <!-- Highlights Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">Destaques</h2>

      <div class="flex flex-col gap-4">
        {resolvedHighlights.map((hl) => {
          if (hl.type === 'project') {
            const project = hl.data;
            const projectYear = project.data.date ? new Date(project.data.date).getFullYear() : '2024';
            return (
              <div class="c-card flex flex-col justify-between space-y-4">
                <div class="space-y-3">
                  <!-- Badge & Year -->
                  <div class="flex items-center justify-between">
                    <span class="c-badge">PROJETO</span>
                    <span class="text-xs text-text-secondary">{projectYear}</span>
                  </div>
                  
                  <h3 class="text-base font-bold text-text-primary">{project.data.title}</h3>
                  
                  <p class="text-sm text-text-secondary leading-relaxed">
                    {project.data.description}
                  </p>
                </div>

                <div class="space-y-4">
                  <!-- Tech stack tags -->
                  {project.data.techStack && (
                    <div class="flex flex-wrap gap-2">
                      {project.data.techStack.map((tech) => (
                        <span class="c-badge">{tech}</span>
                      ))}
                    </div>
                  )}

                  <!-- Action Mini Buttons -->
                  <div class="flex items-center space-x-2 pt-1">
                    {project.data.repository && (
                      <a 
                        href={project.data.repository} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="btn-mini-github"
                      >
                        <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                        </svg>
                        <span>GitHub</span>
                      </a>
                    )}
                    
                    <a href={`/projetos/${project.id}`} class="btn-mini-case">
                      <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      <span>Ler Caso</span>
                    </a>
                  </div>
                </div>
              </div>
            );
          } else if (hl.type === 'paper') {
            const paper = hl.data;
            return (
              <div class="c-card flex flex-col justify-between space-y-4">
                <div class="space-y-3">
                  <!-- Badge & Year -->
                  <div class="flex items-center justify-between">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-accent">
                      PUBLICAÇÃO
                    </span>
                    <span class="text-xs text-text-secondary">{paper.year}</span>
                  </div>

                  <h3 class="text-base font-bold text-text-primary">{paper.title}</h3>
                  
                  <div class="space-y-1">
                    <p class="text-xs text-text-secondary font-medium">{paper.journal}</p>
                    <p class="text-xs text-text-secondary/80">{paper.authors.join(', ')}</p>
                  </div>
                </div>

                {paper.link && (
                  <div class="pt-1">
                    <a 
                      href={paper.link} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class="inline-flex items-center text-xs font-medium text-accent hover:underline"
                    >
                      <span>Ver publicação</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </div>
                )}
              </div>
            );
          }
          return null;
        })}
      </div>

      <!-- Navigation Section Buttons -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">
        <a href="/projetos" class="btn-primary w-full">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span>Ver todos os projetos</span>
        </a>
        
        <a href="/papers" class="btn-primary w-full">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span>Ver todas as publicações</span>
        </a>
      </div>
    </section>

    <!-- Sobre Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{aboutTitle}</h2>
      <p class="text-sm text-text-secondary leading-relaxed" set:html={aboutText}>
      </p>
    </section>

  </div>
</BaseLayout>
