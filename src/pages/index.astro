---
// This is the root redirector page.
// It will detect the user's browser language on the client side and redirect.
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Pedro José Campos de Almeida | Portfólio</title>
    <script is:inline define:vars={{ baseUrl }}>
      (function() {
        let lang = localStorage.getItem('preferred-lang');
        if (!lang) {
          const navLang = navigator.language || navigator.userLanguage || '';
          if (navLang.toLowerCase().startsWith('pt')) {
            lang = 'ptbr';
          } else {
            lang = 'eng';
          }
        }
        window.location.replace(baseUrl + lang + '/');
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${baseUrl}ptbr/`} />
    </noscript>
  </head>
  <body>
    <p>Redirecting / Redirecionando...</p>
  </body>
</html>
