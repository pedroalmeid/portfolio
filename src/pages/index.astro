---
import BaseLayout from '../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';

const homeEntry = await getEntry('info', 'home');

// Safety check for schema compliance
if (!homeEntry || homeEntry.data.schemaType !== 'home') {
  throw new Error('Falha ao carregar dados da página inicial (home.json).');
}

const { heroTitle, heroSubtitle, bio } = homeEntry.data;
---

<BaseLayout title="Daniel Silva | Engenheiro de Software Sênior" description={heroSubtitle}>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center space-y-8 py-12">
    <!-- Badge -->
    <span class="px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider glass text-brand-cyan animate-pulse">
      Disponível para Projetos
    </span>
    
    <!-- Hero Title -->
    <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight max-w-4xl leading-tight">
      Construindo <span class="gradient-text">{heroTitle}</span>
    </h1>
    
    <!-- Hero Subtitle -->
    <p class="text-lg sm:text-xl text-slate-400 max-w-2xl font-light">
      {heroSubtitle}
    </p>

    <!-- Bio Card (Glassmorphic) -->
    <div class="w-full max-w-3xl p-8 rounded-2xl glass glass-hover text-left space-y-4">
      <h2 class="text-xl font-semibold text-slate-100 flex items-center space-x-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <span>Sobre mim</span>
      </h2>
      <p class="text-slate-300 leading-relaxed text-sm sm:text-base">
        {bio}
      </p>
    </div>

    <!-- Quick Navigation Call to Actions -->
    <div class="flex flex-wrap justify-center gap-4 pt-4">
      <a href="/projetos" class="px-6 py-3 rounded-full text-sm font-semibold glass glass-hover bg-brand-purple/20 text-brand-cyan border border-brand-cyan/20 shadow-md">
        Ver Casos de Estudo
      </a>
      <a href="/cv" class="px-6 py-3 rounded-full text-sm font-semibold glass glass-hover text-slate-300">
        Visualizar Currículo
      </a>
      <a href="/contato" class="px-6 py-3 rounded-full text-sm font-semibold glass glass-hover text-slate-300">
        Fale Comigo
      </a>
    </div>
  </div>
</BaseLayout>
