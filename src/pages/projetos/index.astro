---
import BaseLayout from '../../components/astro/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

// Fetch all markdown cases
const cases = await getCollection('cases');

// Fetch additional projects from JSON
const projectsEntry = await getEntry('info', 'projects');
if (!projectsEntry || projectsEntry.data.schemaType !== 'projects') {
  throw new Error('Falha ao carregar dados dos projetos secundários (projects.json).');
}

const secondaryProjects = projectsEntry.data.projects;

// Format date helper
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  }).format(date);
};
---

<BaseLayout title="Projetos & Casos de Estudo | Daniel Silva" description="Exploração de casos de estudo e repositórios desenvolvidos sob arquiteturas estáticas modernas.">
  <div class="space-y-12">
    <!-- Header -->
    <div class="space-y-4">
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight">
        Meus <span class="gradient-text">Projetos</span>
      </h1>
      <p class="text-slate-400 text-base sm:text-lg max-w-2xl font-light">
        Abaixo você encontra casos de estudo detalhados e repositórios open-source criados com separação semântica rígida e otimizados para máxima performance.
      </p>
    </div>

    <!-- Case Studies Section (Markdown) -->
    <div class="space-y-6">
      <h2 class="text-xl sm:text-2xl font-bold tracking-tight text-white border-b border-white/5 pb-2">
        Casos de Estudo Principais (SSG)
      </h2>
      
      <div class="grid grid-cols-1 gap-6">
        {cases.map((project) => (
          <article class="p-6 rounded-2xl glass glass-hover flex flex-col justify-between space-y-4">
            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-xs text-brand-purple font-semibold uppercase tracking-wider">
                  {formatDate(project.data.date)}
                </span>
                {project.data.repository && (
                  <a 
                    href={project.data.repository} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-xs text-slate-400 hover:text-brand-cyan transition-colors"
                  >
                    Repositório →
                  </a>
                )}
              </div>
              <h3 class="text-2xl font-semibold text-white">
                <a href={`/projetos/${project.id}`} class="hover:text-brand-cyan transition-colors">
                  {project.data.title}
                </a>
              </h3>
              <p class="text-slate-300 text-sm sm:text-base leading-relaxed">
                {project.data.description}
              </p>
            </div>
            
            <div class="flex flex-wrap gap-2 pt-2">
              {project.data.techStack.map((tech) => (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/5 border border-white/10 text-slate-300">
                  {tech}
                </span>
              ))}
            </div>

            <div class="pt-2">
              <a href={`/projetos/${project.id}`} class="text-sm font-semibold text-brand-cyan hover:underline inline-flex items-center space-x-1">
                <span>Ler artigo completo</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Secondary Projects Section (JSON) -->
    <div class="space-y-6">
      <h2 class="text-xl sm:text-2xl font-bold tracking-tight text-white border-b border-white/5 pb-2">
        Outros Projetos & Repositórios (JSON)
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {secondaryProjects.map((project) => (
          <div class="p-6 rounded-2xl glass glass-hover flex flex-col justify-between space-y-4">
            <div class="space-y-2">
              <h3 class="text-xl font-semibold text-white">
                {project.name}
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                {project.description}
              </p>
            </div>
            
            <div class="space-y-4">
              {project.techStack && (
                <div class="flex flex-wrap gap-1.5">
                  {project.techStack.map((tech) => (
                    <span class="px-2.5 py-0.5 rounded-full text-[10px] font-medium bg-white/5 border border-white/5 text-slate-400">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
              {project.url && (
                <a 
                  href={project.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="text-xs text-brand-cyan hover:underline inline-flex items-center space-x-1"
                >
                  <span>Ver código fonte</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
