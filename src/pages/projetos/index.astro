---
import BaseLayout from '../../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { FileText } from '@lucide/astro';

// Fetch projects from JSON
const projectsEntry = await getEntry('info', 'projects');
if (!projectsEntry || projectsEntry.data.schemaType !== 'projects') {
  throw new Error('Falha ao carregar dados dos projetos (projects.json).');
}

const projectsList = projectsEntry.data.projects;
---

<BaseLayout title="Projetos | Pedro José" description="Projetos acadêmicos, de pesquisa e pessoais de Pedro José Campos de Almeida.">
  <div class="space-y-8 max-w-2xl">
    
    <!-- Header Section -->
    <div class="space-y-4">
      <span class="c-section-label">Projetos</span>
      
      <h1 class="font-extrabold text-text-primary text-[2.5rem] leading-[1.15] tracking-tight select-none">
        O que eu construo e construí
      </h1>
      
      <p class="text-text-secondary text-sm leading-relaxed">
        Projetos pessoais, acadêmicos, de pesquisa e freelance — todos com código disponível no GitHub. Clique em "Ler Caso" para entender melhor cada uma das soluções, seu contexto, experiência adquirida e entrega.
      </p>
    </div>

    <!-- Projects Grid/List -->
    <div class="flex flex-col gap-4 pt-4">
      {projectsList.map((project) => (
        <div class="c-card flex flex-col justify-between space-y-4">
          
          <div class="space-y-3">
            <!-- Header (Name & Year) -->
            <div class="flex items-center justify-between">
              <h3 class="text-base font-bold text-text-primary">
                {project.name}
              </h3>
              <span class="text-xs text-text-secondary">{project.year}</span>
            </div>
            
            <!-- Description -->
            <p class="text-sm text-text-secondary leading-relaxed">
              {project.description}
            </p>
          </div>

          <div class="space-y-4">
            <!-- Tech Stack Badges -->
            {project.techStack && (
              <div class="flex flex-wrap gap-2">
                {project.techStack.map((tech) => (
                  <span class="c-badge select-none">{tech}</span>
                ))}
              </div>
            )}

            <!-- Action Buttons -->
            <div class="flex items-center space-x-2 pt-1 select-none">
              {project.url && (
                <a 
                  href={project.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="btn-mini-github"
                >
                  <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                  </svg>
                  <span>GitHub</span>
                </a>
              )}
              
              {project.caseSlug && (
                <a 
                  href={`/projetos/${project.caseSlug}`} 
                  class="btn-mini-case"
                >
                  <FileText class="w-3.5 h-3.5 mr-1.5" />
                  <span>Ler Caso</span>
                </a>
              )}
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</BaseLayout>
