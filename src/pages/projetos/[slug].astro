---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import BaseLayout from '../../components/astro/BaseLayout.astro';
import avatarImg from '../../assets/profile.png';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'cases'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Fetch matching project metadata from projects.json
const projectsEntry = await getEntry('info', 'projects');
const project = projectsEntry && projectsEntry.data.schemaType === 'projects'
  ? projectsEntry.data.projects.find((p) => p.caseSlug === entry.id)
  : null;

const year = project ? project.year : new Date(entry.data.date).getFullYear();
const techStack = project ? project.techStack : entry.data.techStack;
const repositoryUrl = project ? project.url : entry.data.repository;
---

<BaseLayout title={`${entry.data.title} | Caso de Estudo`} description={entry.data.description} mainClass="mx-auto">
  <article class="space-y-6 max-w-2xl">
    
    <!-- Breadcrumb Nav -->
    <div class="flex items-center space-x-2 text-xs text-text-secondary select-none mb-6">
      <a href={`${import.meta.env.BASE_URL}projetos`} class="hover:text-accent transition-colors flex items-center">
        <span>&larr; Voltar</span>
      </a>
      <span class="text-border">|</span>
      <span>{entry.data.title}</span>
    </div>

    <!-- Title -->
    <h1 class="font-extrabold text-text-primary text-[2.5rem] leading-[1.15] tracking-tight">
      {entry.data.title}
    </h1>

    <!-- Author & Meta Info Row -->
    <div class="flex items-center space-x-3 select-none">
      <img src={avatarImg.src} alt="Pedro José" class="w-9 h-9 rounded-full border border-border object-cover" />
      <div>
        <div class="font-bold text-xs text-text-primary leading-tight">Pedro José Campos de Almeida</div>
        <div class="text-[10px] text-text-secondary leading-none mt-0.5">
          {year} · {techStack.join(', ')}
        </div>
      </div>
    </div>

    <!-- GitHub Repository Button -->
    {repositoryUrl && (
      <div class="pt-2 select-none">
        <a 
          href={repositoryUrl} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="btn-mini-github px-4! py-2! inline-flex"
        >
          <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          <span>GitHub</span>
        </a>
      </div>
    )}

    <hr class="border-t border-border mt-6 mb-8" />

    <!-- Article Content -->
    <div class="c-prose">
      <Content />
    </div>

  </article>

  <!-- Client-Side Mermaid support -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js" id="mermaid-script"></script>
  <script is:inline>
    (function() {
      const script = document.getElementById('mermaid-script');
      if (script) {
        script.addEventListener('load', () => {
          initializeAndRenderMermaid();
        });
        // Run immediately if already loaded
        if (typeof mermaid !== 'undefined') {
          initializeAndRenderMermaid();
        }
      }

      async function initializeAndRenderMermaid() {
        if (typeof mermaid !== 'undefined') {
          mermaid.initialize({ startOnLoad: false, theme: 'default' });

          const codeBlocks = document.querySelectorAll('pre[data-language="mermaid"], pre[class*="mermaid"], code[class*="mermaid"]');
          if (codeBlocks.length === 0) return;
          
          for (const block of codeBlocks) {
            const rawText = block.innerText || block.textContent;
            const parent = block.tagName === 'CODE' ? block.parentElement : block;
            if (parent) {
              const container = document.createElement('div');
              container.className = 'mermaid my-6 flex justify-center w-full';
              container.textContent = rawText.trim();
              parent.replaceWith(container);
            }
          }
          await mermaid.run();
        }
      }

      // Safeguard for rapid transitions or custom events
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeAndRenderMermaid);
      } else {
        initializeAndRenderMermaid();
      }
    })();
  </script>
</BaseLayout>

<style is:global>
  /* Rich styling for markdown rendered content in Case Studies */
  .c-prose h2 {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .c-prose h2:first-of-type {
    margin-top: 0;
  }
  .c-prose hr + h2 {
    margin-top: 0;
  }
  .c-prose hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
  .c-prose p, .c-prose ul, .c-prose ol, .c-prose li {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.625;
  }
  .c-prose p {
    margin-bottom: 1.5rem;
  }
  .c-prose ul {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .c-prose ol {
    list-style-type: decimal;
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .c-prose li {
    margin-bottom: 0.5rem;
  }
  .c-prose strong, .c-prose b {
    color: var(--color-text-primary);
    font-weight: 700;
  }
  .c-prose pre {
    background-color: var(--color-bg-card) !important;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.8125rem;
    margin: 1.5rem 0;
  }
  .c-prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  .c-prose p > code, .c-prose li > code {
    background-color: var(--color-bg-hover);
    color: var(--color-text-primary);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    border: 1px solid var(--color-border);
  }
</style>
