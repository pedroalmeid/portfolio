---
import BaseLayout from '../../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { Download, ExternalLink } from '@lucide/astro';

export async function getStaticPaths() {
  return [
    { params: { lang: 'ptbr' } },
    { params: { lang: 'eng' } }
  ];
}

const { lang } = Astro.params;
const isEng = lang === 'eng';

const cvEntry = await getEntry('info', 'cv');
if (!cvEntry || cvEntry.data.schemaType !== 'cv') {
  throw new Error('Falha ao carregar dados do currículo (cv.json).');
}

const { 
  name, 
  location, 
  email, 
  summary, 
  education, 
  experience, 
  awards, 
  certifications, 
  volunteer, 
  skills, 
  languages 
} = cvEntry.data[lang as 'ptbr' | 'eng'];

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout lang={lang} title={isEng ? `CV / Resume | ${name}` : `Currículo | ${name}`} description={isEng ? `Professional CV of ${name}.` : `Currículo profissional de ${name}.`}>
  <div class="space-y-12 max-w-2xl select-text">
    
    <!-- Header Section -->
    <div class="space-y-4">
      <span class="c-section-label">{isEng ? "CV / Resume" : "Currículo"}</span>
      
      <div class="flex items-center justify-between gap-4">
        <h1 class="font-extrabold text-text-primary text-[2.5rem] leading-[1.15] tracking-tight">
          {name}
        </h1>
        
        <a 
          href={isEng ? `${baseUrl}CV_PedroAlmeida_ENG.pdf` : `${baseUrl}Curriculo_PedroAlmeida_PTBR.pdf`} 
          download
          class="btn-secondary shrink-0 text-xs py-1.5 px-3 flex items-center select-none"
        >
          <Download class="w-3.5 h-3.5 mr-1.5" />
          <span>PDF</span>
        </a>
      </div>
      
      <p class="text-xs text-text-secondary select-none">
        {location} • {email}
      </p>
    </div>

    <!-- Summary / Presentation Box -->
    <div class="c-card bg-bg-card border border-border p-5 rounded-xl text-sm text-text-secondary leading-relaxed" set:html={summary}>
    </div>

    <!-- Formação Acadêmica Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Education" : "Formação Acadêmica"}</h2>
      
      <div class="relative pl-6 border-l border-border space-y-6">
        {education.map((edu) => (
          <div class="relative space-y-1">
            <!-- Filled blue dot centered on the line -->
            <div class="absolute left-[-28.5px] top-1.5 w-2 h-2 rounded-full bg-accent"></div>
            
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-bold text-sm text-text-primary">{edu.degree}</h3>
              <span class="text-xs text-text-secondary shrink-0">{edu.period}</span>
            </div>
            
            <p class="text-xs font-semibold text-accent leading-none">
              {edu.institution}
            </p>
            
            {edu.details && (
              <p class="text-xs text-text-secondary pt-0.5">
                {edu.details}
              </p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Experiência Profissional e Acadêmica Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Professional & Academic Experience" : "Experiência Profissional e Acadêmica"}</h2>
      
      <div class="relative pl-6 border-l border-border space-y-8">
        {experience.map((exp) => (
          <div class="relative space-y-1">
            <!-- Outlined blue dot centered on the line -->
            <div class="absolute left-[-28.5px] top-1.5 w-2 h-2 rounded-full border-2 border-accent bg-white"></div>
            
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-bold text-sm text-text-primary">{exp.company}</h3>
              <span class="text-xs text-text-secondary shrink-0">{exp.period}</span>
            </div>
            
            <p class="text-xs font-medium italic text-accent leading-none">
              {exp.role}
            </p>
            
            <ul class="list-disc pl-4 mt-2 space-y-1.5 text-xs text-text-secondary leading-relaxed">
              {exp.bullets.map((bullet) => (
                <li set:html={bullet}></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Prêmios e Produção Científica Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Awards & Scientific Publications" : "Prêmios e Produção Científica"}</h2>
      
      <div class="relative pl-6 border-l border-border space-y-6">
        {awards.map((award) => (
          <div class="relative space-y-1">
            <!-- Filled amber dot centered on the line -->
            <div class="absolute left-[-28.5px] top-1.5 w-2 h-2 rounded-full bg-amber-500"></div>
            
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-bold text-sm text-text-primary">{award.title}</h3>
              <span class="text-xs text-text-secondary shrink-0">{award.period}</span>
            </div>
            
            <p class="text-xs text-text-secondary leading-relaxed">
              {award.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cursos e Certificações Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Courses & Certifications" : "Cursos e Certificações"}</h2>
      
      <div class="relative pl-6 border-l border-border space-y-6">
        {certifications.map((cert) => (
          <div class="relative space-y-1">
            <!-- Outlined gray dot centered on the line -->
            <div class="absolute left-[-28.5px] top-1.5 w-2 h-2 rounded-full border-2 border-border bg-white"></div>
            
            <div>
              <h3 class="font-bold text-sm text-text-primary inline">{cert.title}</h3>
              <span class="text-xs text-text-secondary"> {cert.institution}</span>
            </div>
            
            <p class="text-xs text-text-secondary leading-relaxed">
              {cert.description}
            </p>
            
            {cert.url && (
              <a 
                href={cert.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-flex items-center text-xs font-medium text-accent hover:underline pt-1 select-none"
              >
                <span>{isEng ? "View certificate" : "Ver certificado"}</span>
                <ExternalLink class="h-3 w-3 ml-1" />
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Liderança e Voluntariado Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Leadership & Volunteering" : "Liderança e Voluntariado"}</h2>
      
      <div class="relative pl-6 border-l border-border space-y-6">
        {volunteer.map((vol) => (
          <div class="relative space-y-1">
            <!-- Filled gray dot centered on the line -->
            <div class="absolute left-[-28.5px] top-1.5 w-2 h-2 rounded-full bg-text-secondary/50"></div>
            
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-bold text-sm text-text-primary">{vol.role}</h3>
              <span class="text-xs text-text-secondary shrink-0">{vol.period}</span>
            </div>
            
            <p class="text-xs text-text-secondary leading-relaxed">
              {vol.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Habilidades Técnicas Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Technical Skills" : "Habilidades Técnicas"}</h2>
      
      <div class="space-y-4">
        {skills.map((skill) => (
          <div class="flex items-start">
            <span class="w-32 text-xs font-semibold uppercase tracking-widest text-text-secondary shrink-0 pt-1 select-none">
              {skill.category}
            </span>
            <div class="flex flex-wrap gap-2">
              {skill.items.map((item) => (
                <span class="c-badge select-none">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Idiomas Section -->
    <section class="space-y-6">
      <h2 class="c-section-label">{isEng ? "Languages" : "Idiomas"}</h2>
      
      <div class="space-y-3">
        {languages.map((langItem) => (
          <div class="flex items-start">
            <span class="w-32 text-sm font-bold text-text-primary shrink-0 select-none">
              {langItem.name}
            </span>
            <span class="text-sm text-text-secondary">
              {langItem.level}
            </span>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
