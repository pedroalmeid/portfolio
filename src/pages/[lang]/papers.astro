---
import BaseLayout from '../../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { lang: 'ptbr' } },
    { params: { lang: 'eng' } }
  ];
}

const { lang } = Astro.params;
const isEng = lang === 'eng';

const papersEntry = await getEntry('info', 'papers');
if (!papersEntry || papersEntry.data.schemaType !== 'papers') {
  throw new Error('Falha ao carregar dados dos artigos/papers (papers.json).');
}

const papersList = papersEntry.data[lang as 'ptbr' | 'eng'].papers;
---

<BaseLayout 
  lang={lang} 
  title={isEng ? "Publications | Pedro José" : "Publicações | Pedro José"} 
  description={isEng ? "Conference articles and journals in the field of Computer Science." : "Artigos em conferências e periódicos nacionais da área de Ciência da Computação."}
>
  <div class="space-y-8 max-w-2xl">
    
    <!-- Header Section -->
    <div class="space-y-4">
      <span class="c-section-label">{isEng ? "Publications" : "Publicações"}</span>
      
      <h1 class="font-extrabold text-text-primary text-[2.5rem] leading-[1.15] tracking-tight">
        {isEng ? "Published papers" : "Trabalhos publicados"}
      </h1>
      
      <p class="text-text-secondary text-sm leading-relaxed">
        {isEng 
          ? "My articles, academic works, and scientific publications in progress or completed in the field of Computer Science." 
          : "Meus artigos, trabalhos acadêmicos e publicações científicas em andamento ou finalizados na área de Ciência da Computação."
        }
      </p>
    </div>

    <!-- Papers List (Plain layout separated by borders) -->
    <div class="divide-y divide-border space-y-6 [&>*:not(:first-child)]:pt-6 pt-4">
      {papersList.map((paper) => (
        <div class="space-y-2 pb-6">
          
          <!-- Badge and Year Header -->
          <div class="flex items-center justify-between">
            {paper.badge && (
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${
                paper.badgeType === 'blue' 
                  ? 'bg-blue-50 border border-blue-100 text-accent' 
                  : paper.badgeType === 'amber'
                  ? 'bg-amber-50 border border-amber-200 text-amber-700'
                  : 'bg-white border border-border text-text-secondary'
              }`}>
                {paper.badge}
              </span>
            )}
            <span class="text-xs text-text-secondary">{paper.year}</span>
          </div>

          <!-- Paper Title -->
          <h3 class="text-base font-bold text-text-primary">
            {paper.link ? (
              <a 
                href={paper.link} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="hover:text-accent transition-colors"
              >
                {paper.title}
              </a>
            ) : (
              paper.title
            )}
          </h3>

          <!-- Meta Information -->
          <div class="space-y-1">
            <p class="text-xs text-text-secondary font-medium">
              {paper.journal}
            </p>
            <p class="text-xs text-text-secondary/80">
              {paper.authors.join(', ')}
            </p>
          </div>

        </div>
      ))}
    </div>

  </div>
</BaseLayout>
