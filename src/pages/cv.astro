---
import BaseLayout from '../components/astro/BaseLayout.astro';
import { getEntry } from 'astro:content';

const cvEntry = await getEntry('info', 'cv');
if (!cvEntry || cvEntry.data.schemaType !== 'cv') {
  throw new Error('Falha ao carregar dados do currículo (cv.json).');
}

const { education, experience } = cvEntry.data;
---

<BaseLayout title="Currículo Profissional | Daniel Silva" description="Trajetória acadêmica e profissional de Daniel Silva, engenheiro de software sênior.">
  <div class="space-y-12">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="space-y-2">
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight">
          Meu <span class="gradient-text">Currículo</span>
        </h1>
        <p class="text-slate-400 text-base sm:text-lg max-w-2xl font-light">
          Uma visão geral da minha trajetória educacional e profissional na construção de sistemas de alto impacto.
        </p>
      </div>

      <a 
        href="#" 
        onclick="window.print(); return false;" 
        class="px-5 py-2.5 rounded-full text-xs font-semibold uppercase tracking-wider glass glass-hover text-white flex items-center space-x-1.5 self-start sm:self-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        <span>Imprimir / PDF</span>
      </a>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 gap-12">
      <!-- Experience Section -->
      <section class="space-y-6">
        <h2 class="text-2xl font-bold tracking-tight text-white border-b border-white/5 pb-2 flex items-center space-x-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>Experiência Profissional</span>
        </h2>
        
        <div class="space-y-8 relative before:absolute before:top-2 before:bottom-2 before:left-[11px] before:w-[2px] before:bg-white/5">
          {experience.map((exp) => (
            <div class="relative pl-8 space-y-2">
              <!-- Dot Indicator -->
              <span class="absolute top-2 left-[5px] w-3.5 h-3.5 rounded-full bg-brand-cyan border-4 border-bg-dark shadow-[0_0_10px_rgba(0,242,254,0.5)]"></span>
              
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1">
                <h3 class="text-lg sm:text-xl font-semibold text-white">
                  {exp.role} <span class="text-brand-purple">@ {exp.company}</span>
                </h3>
                <span class="text-xs sm:text-sm text-slate-400 font-medium">
                  {exp.period}
                </span>
              </div>
              <p class="text-slate-300 text-sm sm:text-base leading-relaxed">
                {exp.description}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- Education Section -->
      <section class="space-y-6">
        <h2 class="text-2xl font-bold tracking-tight text-white border-b border-white/5 pb-2 flex items-center space-x-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-neon-pink" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
          </svg>
          <span>Formação Acadêmica</span>
        </h2>
        
        <div class="space-y-8 relative before:absolute before:top-2 before:bottom-2 before:left-[11px] before:w-[2px] before:bg-white/5">
          {education.map((edu) => (
            <div class="relative pl-8 space-y-1">
              <!-- Dot Indicator -->
              <span class="absolute top-2 left-[5px] w-3.5 h-3.5 rounded-full bg-neon-pink border-4 border-bg-dark shadow-[0_0_10px_rgba(244,63,94,0.5)]"></span>
              
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1">
                <h3 class="text-lg font-semibold text-white">
                  {edu.degree}
                </h3>
                <span class="text-xs sm:text-sm text-slate-400 font-medium">
                  {edu.period}
                </span>
              </div>
              <p class="text-brand-purple text-sm font-medium">
                {edu.institution}
              </p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
